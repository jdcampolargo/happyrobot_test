# Local development key. Rotate before deployment.
API_KEY=local-dev-key

# Optional. If omitted, carrier verification uses deterministic mock data for demoability.
FMCSA_WEB_KEY=

# SQLite path. The app creates and seeds this on startup.
DATABASE_PATH=data/app.db

# Dashboard branding.
BROKER_NAME=Acme Logistics
ENVIRONMENT=development
